# Backend API URL (no trailing slash)
NEXT_PUBLIC_API_URL=https://tubeai-backend.vercel.app

# Cloudflare Turnstile
# Get your site key from https://dash.cloudflare.com → Turnstile → your widget
# This key is public — safe to expose in the browser.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_cloudflare_turnstile_site_key_here
