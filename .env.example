# Backend API URL — REQUIRED
# Must point to your deployed backend. For Vercel deployment:
NEXT_PUBLIC_API_URL=https://vu-web-backend.vercel.app

# Google OAuth — optional, Google login button hidden if blank
# Get Client ID from https://console.cloud.google.com/apis/credentials
# Add these to Authorised JavaScript origins in Google Console:
#   https://vu-web-front-rho.vercel.app
#   http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Cloudflare Turnstile CAPTCHA — optional
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
